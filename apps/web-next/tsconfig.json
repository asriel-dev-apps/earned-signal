{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    // Vite/React Router does the building; tsc is typecheck-only. `noEmit` keeps a
    // bare `tsc` (without --noEmit) from transpiling .js next to every source file.
    "noEmit": true,
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["./worker-configuration.d.ts", "vite/client", "node"]
  },
  "include": [
    "app",
    "workers",
    "test",
    "vite.config.ts",
    "vitest.config.ts",
    "react-router.config.ts",
    "worker-configuration.d.ts",
    ".react-router/types/**/*"
  ]
}
