{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "vecta-next-local",
  "main": "./workers/app.ts",
  "compatibility_date": "2026-07-17",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": "./build/client"
  },
  "observability": {
    "enabled": true
  }
}
