{
  "name": "@earned-signal/persistence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earned-signal/application": "workspace:*",
    "@earned-signal/domain": "workspace:*",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "24.10.1",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
