{
  "name": "vecta",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm test:operations && pnpm build",
    "lint": "eslint .",
    "test": "pnpm --recursive test",
    "test:operations": "node --test .github/scripts/*.test.mjs",
    "typecheck": "pnpm --recursive typecheck",
    "types:worker": "pnpm --recursive --filter './apps/**' --if-present types:worker"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
